# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# For development (SQLite): set DB_ENGINE=sqlite3 and leave others empty
# For production (PostgreSQL): set DB_ENGINE=postgresql and fill in the rest
DB_ENGINE=sqlite3
DB_NAME=lms_database
DB_USER=lms_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email Settings
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Security & Performance
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=30
LOGIN_THROTTLE_RATE=5/min

# AI Core Config (Provider-Agnostic)
# AI_PROVIDER: pollin | openai | gemini
AI_PROVIDER=pollin
AI_MODEL=openai
AI_TEMPERATURE=0.7
AI_TIMEOUT=30

# Keys and URLs
# For Pollinations
POLLINATIONS_BASE_URL=https://gen.pollinations.ai
POLLINATIONS_API_KEY=your-pollinations-key

# For official OpenAI
# OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# For future providers
# AI_API_KEY=some-key
# AI_BASE_URL=some-url
